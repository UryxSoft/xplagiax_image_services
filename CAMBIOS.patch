@@ -86,6 +86,68 @@ ZENSERP_MONTHLY_LIMIT=50
 API_CIRCUIT_FAILURE_THRESHOLD=5
 API_CIRCUIT_RECOVERY_S=120
 
+# ==============================================================================
+# Reverse Image Search — lightweight external-API orchestrator (no local ML)
+#
+# Providers are tried in ascending PRIORITY order. As soon as one returns a
+# similarity >= its own STOP_THRESHOLD, the chain stops immediately — no
+# further providers are called, no further quota is spent. If none clears
+# its threshold, the best result found across all tried providers is
+# returned. See app/reverse_search/orchestrator.py.
+#
+# Deployable two ways:
+#   1. Bundled in this monolith (app.factory:create_app) — shares this
+#      process's RAM with CLIP/SigLIP/Qdrant regardless of use.
+#   2. Standalone (app.reverse_search.app:create_app) — a genuinely separate,
+#      torch-free process. See requirements-reverse-search.txt and
+#      docker/Dockerfile.reverse-search / docker-compose.reverse-search.yml.
+# ==============================================================================
+REVERSE_SEARCH_ENABLED=true
+REVERSE_SEARCH_MAX_PROVIDERS=3
+REVERSE_SEARCH_MAX_RETRIES=2
+# Cap on images per POST /api/v1/reverse-image-search/batch request
+REVERSE_SEARCH_MAX_BATCH_SIZE=20
+# Asymmetric cache TTLs (seconds): a discovered copy rarely un-appears, but
+# "not found today" can flip to "found" as provider indexes grow.
+REVERSE_SEARCH_CACHE_TTL_FOUND=2592000      # 30 days
+REVERSE_SEARCH_CACHE_TTL_NOT_FOUND=86400    # 1 day
+# Required ONLY if a URL-based provider (Serper) is enabled — this service's
+# own public URL, used to hand providers a fetchable link to the upload for
+# the few seconds their crawler needs it.
+REVERSE_SEARCH_PUBLIC_BASE_URL=
+REVERSE_SEARCH_TEMP_HOSTING_TTL=120
+
+# Google Vision API — WEB_DETECTION feature. Sends image bytes inline
+# (base64), so no public URL is needed — this is why it is priority 1 by
+# default: the common case never pays the temp-hosting cost at all.
+GOOGLE_VISION_API_KEY=
+GOOGLE_VISION_ENABLED=true
+GOOGLE_VISION_PRIORITY=1
+GOOGLE_VISION_STOP_THRESHOLD=98
+GOOGLE_VISION_TIMEOUT=5
+
+# Serper.dev — Google Lens endpoint (google.serper.dev/lens). NOTE: this is
+# NOT the same as Serper's plain /search endpoint (text web search — cannot
+# do reverse image lookup), and Serper.dev is NOT the same company as
+# SerpApi.com (already used by SERPAPI_KEY above for patent search). Needs a
+# public image URL, hence lower priority than Google Vision.
+SERPER_API_KEY=
+SERPER_ENABLED=true
+SERPER_PRIORITY=2
+SERPER_STOP_THRESHOLD=95
+SERPER_TIMEOUT=6
+
+# Mungfali — EXPERIMENTAL / disabled by default. Its documented public API is
+# a keyword/stock image search product, not a verified image-upload reverse-
+# search endpoint. This adapter is a structurally-complete template that
+# always raises ProviderUnavailableError (safely skipped) until the real
+# contract is confirmed with the vendor. See app/reverse_search/providers/mungfali.py.
+MUNGFALI_API_KEY=
+MUNGFALI_ENABLED=false
+MUNGFALI_PRIORITY=3
+MUNGFALI_STOP_THRESHOLD=90
+MUNGFALI_TIMEOUT=5
+
 # ==============================================================================
 # Observability
 # ==============================================================================
