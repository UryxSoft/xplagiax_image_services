diff --git a/.env.example b/.env.example
index cc7f863..f5580d0 100644
--- a/.env.example
+++ b/.env.example
@@ -148,6 +148,42 @@ MUNGFALI_PRIORITY=3
 MUNGFALI_STOP_THRESHOLD=90
 MUNGFALI_TIMEOUT=5
 
+# --- Speed -------------------------------------------------------------
+# Retry-time budget for the WHOLE request (seconds). Once past it, a
+# provider's own retry_call() stops retrying and the sequential chain stops
+# trying further providers — bounds worst-case latency instead of letting
+# retries on a slow/flaky provider add up unbounded.
+REVERSE_SEARCH_REQUEST_DEADLINE_S=12
+# "cost" (default): sequential Early Stop, exactly as documented above.
+# "latency": call every configured provider CONCURRENTLY instead — wall time
+# becomes the slowest provider's timeout instead of the sum of all of them,
+# but every provider's quota is always spent (no early stop before calling).
+# Explicit cost-for-speed trade; can also be overridden per-request.
+REVERSE_SEARCH_MODE=cost
+# Cap on images processed concurrently within one /batch request (via a
+# bounded gevent pool) — independent of MAX_BATCH_SIZE, so a big batch can't
+# exhaust the shared connection pool or burst the provider's own rate limit.
+REVERSE_SEARCH_BATCH_CONCURRENCY=10
+
+# --- Accuracy ------------------------------------------------------------
+# If two DIFFERENT providers independently report a match on the same
+# hostname in one request, that's corroborating evidence — similarity gets
+# this bonus (capped at 99.9).
+REVERSE_SEARCH_CORROBORATION_BONUS=5
+# Optional domain trust adjustments. Empty by default — they only do
+# anything once you populate them; nothing is assumed about any domain.
+REVERSE_SEARCH_TRUSTED_DOMAINS=
+REVERSE_SEARCH_TRUSTED_DOMAIN_BONUS=3
+REVERSE_SEARCH_DISTRUSTED_DOMAINS=
+REVERSE_SEARCH_DISTRUSTED_DOMAIN_PENALTY=10
+
+# Per-provider circuit breaker (Redis-backed, shared with the SAME
+# CircuitBreaker class api_rotator.py already uses) — trips after this many
+# SUSTAINED failures across requests (not retries within one), skipping the
+# provider entirely until the recovery window passes.
+REVERSE_SEARCH_CIRCUIT_FAILURE_THRESHOLD=5
+REVERSE_SEARCH_CIRCUIT_RECOVERY_S=120
+
 # ==============================================================================
 # Observability
 # ==============================================================================
