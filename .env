# XplagiaX Images Search Services Environment Configuration
# Copy this file to .env and adjust values for your deployment

# ==============================================================================
# Security & Authentication
# ==============================================================================
# Master API Key required for all endpoints (must match X-API-Key header)
SERVICE_API_KEY=your_secure_api_key_here

# Enable/disable authentication (set to false ONLY for local dev)
REQUIRE_AUTH=false

# ==============================================================================
# Infrastructure Connections
# ==============================================================================
# Qdrant Vector Database
QDRANT_HOST=:memory:
QDRANT_PORT=6333

# Redis Cache and Job Queue
REDIS_HOST=
REDIS_PORT=6379
# REDIS_PASSWORD=

# ==============================================================================
# Object Storage (SeaweedFS)
# ==============================================================================
# Backends: local | seaweedfs_filer | seaweedfs_native
IMAGE_BACKEND=local
IMAGE_BASE_PATH=./data/images

# Filer connection (when IMAGE_BACKEND=seaweedfs_filer)
SEAWEEDFS_FILER_URL=http://localhost:8888

# Master connection (when IMAGE_BACKEND=seaweedfs_native)
SEAWEEDFS_MASTER_URL=http://localhost:9333

# Storage parameters
SEAWEEDFS_REPLICATION=000
SEAWEEDFS_COLLECTION=xplagiax

# ==============================================================================
# Machine Learning Models
# ==============================================================================
# Device: cpu | cuda | auto
MODEL_DEVICE=auto

# ==============================================================================
# External API Rotators
# ==============================================================================
# Keys for reverse-image and patent searches
# SERPAPI_KEY=your_serpapi_key_here
# ZENSERP_KEY=your_zenserp_key_here

# ==============================================================================
# Flask Application & Observability
# ==============================================================================
PROMETHEUS_ENABLED=false
FLASK_DEBUG=true
PORT=5006
LOG_LEVEL=DEBUG
LOG_FORMAT=json
ENVIRONMENT=development
